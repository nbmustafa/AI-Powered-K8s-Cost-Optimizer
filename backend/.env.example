# ── EKS Cost Optimizer — Backend environment variables ────────────────────────
# Copy to .env and fill in your values:
#   cp backend/.env.example backend/.env
#
# Used by:
#   - uvicorn (local dev):  cd backend && uvicorn app.main:app --reload
#   - docker compose:       reads from env vars (not this file directly)

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR-KEY-HERE

# ── Kubernetes ────────────────────────────────────────────────────────────────
K8S_IN_CLUSTER=false
# KUBECONFIG defaults to ~/.kube/config when K8S_IN_CLUSTER=false

CLUSTER_NAME=your-cluster-name

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Leave blank to use ~/.aws/credentials or instance profile

# ── Observability ─────────────────────────────────────────────────────────────
# Set to your Prometheus URL — or leave blank to fall back to CloudWatch
PROMETHEUS_URL=http://localhost:9090
METRICS_LOOKBACK_HOURS=24

# ── App behaviour ─────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=60
LOG_LEVEL=DEBUG
CORS_ORIGINS=["*"]

# ── Static files ──────────────────────────────────────────────────────────────
# Point at the React build output when running the backend locally.
# Leave unset in production — the Dockerfile sets STATIC_FILES_DIR=/app/static.
# STATIC_FILES_DIR=../frontend/build
