# ── EKS Cost Optimizer — Frontend environment variables ───────────────────────
# Copy to .env.local for local development:
#   cp frontend/.env.example frontend/.env.local
#
# These are baked into the React build at `npm run build` time.
# For runtime config (API URL), see public/config.js + backend/entrypoint.sh.

# ── CRA standard ─────────────────────────────────────────────────────────────
# All custom vars must be prefixed with REACT_APP_

# Base URL of the backend API.
# In production this is empty (same-origin). In split-host setups, set it here.
# REACT_APP_API_URL=https://eks-cost-optimizer-api.internal.company.com

# ── Development proxy ─────────────────────────────────────────────────────────
# The "proxy" field in package.json already proxies /api/* to :8080.
# You only need REACT_APP_API_URL if you want to hit a remote backend.
